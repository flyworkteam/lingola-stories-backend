generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL") 
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  email     String? @unique
  isPremium Boolean @default(false)

  deviceId String? @unique

  googleSub   String? @unique
  appleSub    String? @unique
  facebookSub String? @unique

  profile         ProfileData?
  interests       UserInterest[]
  targetLanguages UserTargetLanguage[]

  author       Author?
  storyRatings StoryRating[]

  userWords UserWord[]

  bookProgress    UserBookProgress[]
  bookCompletions UserBookCompletion[]

  notifications UserNotification[]
}


model UserNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  
  // Bildirimin okundu bilgisi
  read      Boolean  @default(false)
  readAt    DateTime?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Bildirim başlığı ve içeriği (Çok dilli yapıya uygun olarak gönderilen dili saklayabilirsiniz veya key tutabilirsiniz)
  title     String
  message   Json

  scheduledFor DateTime @default(now())
  
  // Bildirimin tipi (örn: "reminder", "system", "promotion", "achievement")
  type      String   @default("system")

  // Opsiyonel: Bildirime tıklandığında gidilecek yer (deeplink veya route name)
  actionUrl String?  

  // Opsiyonel: OneSignal gibi servislerden gelen ID'yi tutmak isterseniz
  externalId String?

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model ProfileData {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique

  name                    String?
  appLanguage             String?
  currentLearningLanguage String?
  avatarUrl               String?

  ageRange        String?
  currentLevel    String?
  listeningLevel  String?
  dailyGoalMin    Int?
  notificationsOn Boolean @default(false)

  isComplete  Boolean   @default(false)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isComplete])
}

model UserInterest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  interest String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, interest])
  @@index([interest])
  @@index([userId])
}

model UserTargetLanguage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  language String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language])
  @@index([language])
  @@index([userId])
}

// =====================
// AUTHOR
// =====================

model Author {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type String @default("studio")
  name String

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  stories Story[]

  @@index([type])
  @@index([name])
}

// =====================
// STORY
// =====================

model Story {
  id String @id @default(cuid())

  authorId String?
  author   Author? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  level   String
  batchId String?
  status  String  @default("draft")

  // ✅ Kitap toplam kelime sayısı (metinden hesaplanıp yazılabilir)
  totalWords Int @default(0)
  averageRating Float @default(0) 
  ratingCount   Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  localizations StoryLocalization[]
  assets        StoryAsset[]
  tags          StoryTag[]
  ratings       StoryRating[]

  progresses  UserBookProgress[]
  completions UserBookCompletion[]

  @@index([level])
  @@index([status])
  @@index([authorId])
  @@index([averageRating])
}

model StoryLocalization {
  id      Int    @id @default(autoincrement())
  storyId String
  lang    String

  title   String
  text    String @db.Text
  summary String @db.Text

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, lang])
  @@index([lang])
  @@index([storyId])
}

model Tag {
  id   Int    @id @default(autoincrement())
  slug String @unique
  name String

  stories StoryTag[]
}

model StoryTag {
  storyId String
  tagId   Int

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([storyId, tagId])
  @@index([tagId])
}

model StoryAsset {
  id        Int     @id @default(autoincrement())
  storyId   String
  assetType String // "cover" | "audio"
  lang      String? // audio için, cover null
  url       String
  meta      Json?

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([assetType])
  @@index([lang])
}

model StoryRating {
  id      Int    @id @default(autoincrement())
  storyId String
  userId  String
  rating  Int

  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([userId])
}

// =====================
// USER WORDS (Library)
// =====================

model UserWord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String

  sourceLang String @default("en")
  word       String
  targetLang String

  translation String? @db.Text
  level       String?

  isFav Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceLang, word, targetLang], name: "uniq_user_word_per_lang")
  @@index([userId, isFav])
  @@index([userId, targetLang])
  @@index([userId, updatedAt])
  @@index([word])
}

// =====================
// USER BOOK PROGRESS
// =====================

model UserBookProgress {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  storyId String

  bookmarkWordIndex Int @default(0)
  totalWords        Int @default(0)
  progressPercent   Int @default(0)

  // opsiyonel: okuma state (ileride çok işe yarar)
  status String @default("reading") // "reading" | "completed"

  lastReadAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId], name: "uniq_user_story_progress")
  @@index([userId, lastReadAt])
  @@index([storyId])
}

// =====================
// USER BOOK COMPLETION
// =====================

model UserBookCompletion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId  String
  storyId String

  completedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId], name: "uniq_user_story_completion")
  @@index([userId, completedAt])
  @@index([storyId])
}